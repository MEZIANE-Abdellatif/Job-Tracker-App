# Prisma and the API use a Postgres URI — not JDBC.
#
# If your tool shows:
#   jdbc:postgresql://localhost:5432/task_manager
# use this shape in .env (replace USER / PASSWORD):
#
#   postgresql://USER:PASSWORD@localhost:5432/task_manager
#
# URL-encode special characters in PASSWORD (e.g. @ → %40).

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/task_manager"

# Required JWT secrets (32+ random chars each in production)
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Optional
# PORT=3001
# CORS_ORIGIN=http://localhost:3000
